{
  "name": "cronos",
  "private": true,
  "version": "0.0.7",
  "author": "munozrc",
  "license": "MIT",
  "description": "Music downloader in mp3 format using ElectronJS and ReactJS",
  "main": "dist/index.js",
  "scripts": {
    "build:app": "tsc && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dev:app": "vite",
    "dev:electron": "npm run build:electron && electron .",
    "release": "npm run build:app && npm run build:electron && electron-builder build --publish never"
  },
  "dependencies": {
    "axios": "0.27.2",
    "fluent-ffmpeg": "2.1.2",
    "node-id3": "0.2.3",
    "node-youtube-music": "0.7.0",
    "react": "18.0.0",
    "react-dom": "18.0.0",
    "react-router-dom": "6.3.0",
    "ytdl-core": "4.11.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "2.1.20",
    "@types/react": "18.0.0",
    "@types/react-dom": "18.0.0",
    "@typescript-eslint/eslint-plugin": "5.27.0",
    "@typescript-eslint/parser": "5.27.0",
    "@vitejs/plugin-react": "1.3.0",
    "electron": "19.0.3",
    "electron-builder": "23.0.3",
    "eslint": "8.17.0",
    "eslint-config-standard": "17.0.0",
    "eslint-plugin-import": "2.26.0",
    "eslint-plugin-n": "15.2.1",
    "eslint-plugin-promise": "6.0.0",
    "eslint-plugin-react": "7.30.0",
    "typescript": "4.6.3",
    "vite": "2.9.9",
    "zustand": "4.0.0-rc.1"
  },
  "build": {
    "appId": "com.munozrc.cronos",
    "productName": "Cronos",
    "asar": true,
    "directories": {
      "output": "release/${version}",
      "buildResources": "app/resources"
    },
    "files": [
      "dist"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "ia32"
          ]
        }
      ],
      "artifactName": "cronos-windows-${version}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}